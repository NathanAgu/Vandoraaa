{% extends 'base.html.twig' %}

{% block title %}{{ user.username }} - Profil vendeur - Vandora{% endblock %}

{% block body %}
<style>
    .profile-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 2rem;
    }

    .profile-header {
        background: linear-gradient(135deg, #09b1ba 0%, #0d8a92 100%);
        color: white;
        padding: 3rem 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        text-align: center;
    }

    .profile-header h1 {
        font-size: 2.5rem;
        margin: 0 0 1rem 0;
    }

    .profile-info {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #09b1ba;
        margin-bottom: 0.5rem;
    }

    .stat-label {
        color: #666;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    .articles-section {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .articles-section h2 {
        margin-top: 0;
        color: #333;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #09b1ba;
        padding-bottom: 1rem;
    }

    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1.5rem;
    }

    .article-card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e5e5e5;
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

    .article-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
    }

    .article-image {
        background: #f5f5f5;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
    }

    .article-content {
        padding: 1rem;
    }

    .article-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .article-price {
        font-size: 1.3rem;
        color: #09b1ba;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .article-details {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: #666;
    }

    .article-card a {
        text-decoration: none;
        color: inherit;
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        color: #999;
    }

    .empty-state p {
        font-size: 1.1rem;
        margin-bottom: 1rem;
    }

    .btn-back {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        background: white;
        color: #09b1ba;
        border: 2px solid #09b1ba;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 2rem;
        transition: all 0.2s;
    }

    .btn-back:hover {
        background: #09b1ba;
        color: white;
    }

    .user-description {
        background: #f9f9f9;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        border-left: 4px solid #09b1ba;
    }

    .user-description p {
        margin: 0;
        color: #555;
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        .profile-info {
            grid-template-columns: repeat(2, 1fr);
        }

        .profile-header h1 {
            font-size: 1.8rem;
        }

        .articles-grid {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        }
    }
</style>

<div class="profile-container">
    <a href="{{ path('app_home') }}" class="btn-back">← Retour à l'accueil</a>

    <div class="profile-header">
        <h1>{{ user.username }}</h1>
        <p>Profil du vendeur</p>
    </div>

    {% if user.description %}
        <div class="user-description">
            <p>{{ user.description }}</p>
        </div>
    {% endif %}

    <div class="profile-info">
        <div class="stat-card">
            <div class="stat-number">{{ user.articles|length }}</div>
            <div class="stat-label">Articles en vente</div>
        </div>

        <div class="stat-card">
            <div class="stat-number">{{ user.reviews|length }}</div>
            <div class="stat-label">Avis reçus</div>
        </div>

        <div class="stat-card">
            <div class="stat-number">{{ user.orders|length }}</div>
            <div class="stat-label">Achats effectués</div>
        </div>

        <div class="stat-card">
            <div class="stat-number">{{ user.favorites|length }}</div>
            <div class="stat-label">Favorites</div>
        </div>
    </div>

    <div class="articles-section">
        <h2>Articles en vente</h2>

        {% if user.articles|length > 0 %}
            <div class="articles-grid">
                {% for article in user.articles %}
                    <a href="{{ path('app_article_show', {'id': article.id}) }}" class="article-card">
                        <div class="article-image">📦</div>
                        <div class="article-content">
                            <div class="article-name">{{ article.name }}</div>
                            <div class="article-price">{{ article.price|number_format(2, ',', ' ') }} €</div>
                            <div class="article-details">
                                <span>{{ article.state }}</span>
                                <span>{{ article.createdAt|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <p>Ce vendeur n'a pas d'articles en vente pour le moment.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
